# Deployment mode: "local" (default) or "server"
# - local: user needs yt-dlp/ffmpeg on their machine, sets download folder via UI
# - server: tools bundled on server, files served via browser download (IDM compatible)
DEPLOYMENT_MODE=local

# Path to yt-dlp binary (auto-detected from PATH if not set)
# YTDLP_PATH=yt-dlp

# Directory containing ffmpeg binary (auto-detected from PATH if not set)
# FFMPEG_DIR=/usr/bin

# Server temp directory for downloads (server mode only)
# DOWNLOAD_DIR=/tmp/ytmagnet-downloads
